<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your Feedback Is Requested</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">

  <!-- Wrapper -->
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f7;padding:40px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg,#4f46e5 0%,#7c3aed 100%);border-radius:12px 12px 0 0;padding:40px 48px 36px;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td>
                    <!-- Wordmark -->
                    <span style="font-size:26px;font-weight:800;color:#ffffff;letter-spacing:-0.5px;">
                      loop<span style="color:#c4b5fd;">ly</span>
                    </span>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top:24px;">
                    <p style="margin:0;font-size:13px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#c4b5fd;">Feedback Request</p>
                    <h1 style="margin:8px 0 0;font-size:28px;font-weight:700;color:#ffffff;line-height:1.3;">
                      Your opinion matters to us
                    </h1>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Body card -->
          <tr>
            <td style="background:#ffffff;padding:40px 48px;border-left:1px solid #e5e7eb;border-right:1px solid #e5e7eb;">

              <!-- Greeting -->
              <p style="margin:0 0 20px;font-size:16px;color:#374151;">
                Hi <strong>{{customerName}}</strong>,
              </p>

              <!-- Intro paragraph -->
              <p style="margin:0 0 24px;font-size:16px;color:#374151;line-height:1.6;">
                <strong>{{companyName}}</strong> has requested your feedback on
                <span style="display:inline-block;background:#ede9fe;color:#5b21b6;padding:2px 10px;border-radius:20px;font-size:14px;font-weight:600;">{{productName}}</span>.
                Your honest thoughts help them build a better product — and it only takes a few minutes.
              </p>

              {{#if optionalMessage}}
              <!-- Optional personal note -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:28px;">
                <tr>
                  <td style="border-left:4px solid #7c3aed;padding:14px 20px;background:#faf5ff;border-radius:0 8px 8px 0;">
                    <p style="margin:0 0 4px;font-size:11px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:#7c3aed;">A note from {{companyName}}</p>
                    <p style="margin:0;font-size:15px;color:#4b5563;font-style:italic;line-height:1.6;">"{{optionalMessage}}"</p>
                  </td>
                </tr>
              </table>
              {{/if}}

              <!-- CTA button -->
              <table cellpadding="0" cellspacing="0" style="margin:0 auto 28px;">
                <tr>
                  <td align="center" style="border-radius:8px;background:linear-gradient(135deg,#4f46e5 0%,#7c3aed 100%);">
                    <a href="{{reviewUrl}}"
                       target="_blank"
                       style="display:inline-block;padding:16px 40px;font-size:16px;font-weight:700;color:#ffffff;text-decoration:none;border-radius:8px;letter-spacing:0.3px;">
                      Share Your Feedback &rarr;
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Fallback URL -->
              <p style="margin:0 0 24px;font-size:13px;color:#9ca3af;text-align:center;line-height:1.5;">
                Button not working? Copy and paste this link into your browser:<br/>
                <a href="{{reviewUrl}}" style="color:#6d28d9;word-break:break-all;">{{reviewUrl}}</a>
              </p>

              <!-- Divider -->
              <hr style="border:none;border-top:1px solid #e5e7eb;margin:28px 0;" />

              <!-- Expiry notice -->
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td width="20" valign="top" style="padding-top:2px;">
                    <!-- Clock icon (emoji fallback) -->
                    <span style="font-size:14px;">&#x23F0;</span>
                  </td>
                  <td>
                    <p style="margin:0;font-size:13px;color:#6b7280;line-height:1.5;">
                      This link is personal to you and expires on <strong>{{expiresAt}}</strong>.
                      Please don't share it with others.
                    </p>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f9fafb;border:1px solid #e5e7eb;border-top:none;border-radius:0 0 12px 12px;padding:24px 48px;">
              <p style="margin:0 0 6px;font-size:13px;color:#9ca3af;text-align:center;">
                Sent by <strong style="color:#6d28d9;">Looply</strong> on behalf of {{companyName}}.
              </p>
              <p style="margin:0;font-size:12px;color:#d1d5db;text-align:center;">
                If you weren't expecting this email, you can safely ignore it.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
