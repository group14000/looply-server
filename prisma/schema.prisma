// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String?  @unique
  firstName    String?
  lastName     String?
  imageUrl     String?
  organization Json?

  // Solo/B2C billing — source: Clerk CommerceSubscription, payerType 'user'
  billingPlanId         String?
  billingStatus         String?
  billingSubscriptionId String?
  billingPeriodEnd      DateTime?
  billingSyncedAt       DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Organization {
  id         String  @id @default(cuid())
  clerkOrgId String  @unique
  name       String?
  slug       String?
  imageUrl   String?

  // Org/B2B billing — source: Clerk CommerceSubscription, payerType 'org'
  billingPlanId         String?
  billingStatus         String?
  billingSubscriptionId String?
  billingPeriodEnd      DateTime?
  billingSyncedAt       DateTime?

  products         Product[]
  feedbackRequests FeedbackRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  feedbackRequests FeedbackRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("products")
}

enum FeedbackRequestStatus {
  PENDING
  OPENED
  COMPLETED
  EXPIRED
}

model FeedbackRequest {
  id              String                @id @default(cuid())
  customerName    String
  companyName     String
  email           String
  optionalMessage String?
  token           String                @unique
  status          FeedbackRequestStatus @default(PENDING)
  expiresAt       DateTime?

  productId String
  product   Product @relation(fields: [productId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([organizationId])
  @@map("feedback_requests")
}

model ProcessedWebhookEvent {
  id        String   @id @default(cuid())
  svixId    String   @unique
  eventType String
  createdAt DateTime @default(now())

  @@map("processed_webhook_events")
}
